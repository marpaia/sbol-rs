@prefix : <https://sbolstandard.org/examples/> .
@prefix EDAM: <https://identifiers.org/edam:> .
@prefix SBO: <https://identifiers.org/SBO:> .
@prefix SO: <https://identifiers.org/SO:> .
@prefix sbol: <http://sbols.org/v3#> .

:E0040 a sbol:Component ;
    sbol:displayId "E0040" ;
    sbol:hasFeature <https://sbolstandard.org/examples/E0040/SequenceFeature1> ;
    sbol:hasNamespace <https://sbolstandard.org/examples> ;
    sbol:hasSequence :E0040_Sequence1 ;
    sbol:name "E0040" ;
    sbol:role SO:0000316 ;
    sbol:type SBO:0000251 .

<https://sbolstandard.org/examples/E0040/SequenceFeature1> a sbol:SequenceFeature ;
    sbol:displayId "SequenceFeature1" ;
    sbol:hasLocation <https://sbolstandard.org/examples/E0040/SequenceFeature1/Range1> .

<https://sbolstandard.org/examples/E0040/SequenceFeature1/Range1> a sbol:Range ;
    sbol:displayId "Range1" ;
    sbol:end "3" ;
    sbol:hasSequence :E0040_Sequence1 ;
    sbol:start "1" .

:E0040_Sequence1 a sbol:Sequence ;
    sbol:description "E0040 sequence" ;
    sbol:displayId "E0040_Sequence1" ;
    sbol:elements "" ;
    sbol:encoding EDAM:format_1207 ;
    sbol:hasNamespace <https://sbolstandard.org/examples> ;
    sbol:name "Sequence1" .

